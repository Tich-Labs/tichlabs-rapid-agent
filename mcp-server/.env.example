# Firebase Admin SDK (required — replaces Supabase)
# Paste the entire contents of your Firebase service account JSON key file
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# LLM provider (first detected wins — falls back to keyword matching if none set)
# Option 1: Gemini (hackathon default)
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash

# Option 2: OpenAI (paid)
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini

# Option 3: Groq (free, hosted)
GROQ_API_KEY=gsk_your-groq-key
GROQ_MODEL=llama-3.3-70b-versatile

# Option 4: Ollama (free, local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# MongoDB (for case document storage, search, analytics)
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net
MONGODB_DB_NAME=tichlabs_cases

# HTTP transport (for cloud deployment)
MCP_TRANSPORT=http
MCP_API_KEY=your-secret-api-key-here
PORT=3001
